# کپی: copy .env.example .env

# توسعه: DEBUG=True | سرور: DEBUG=False
DEBUG=True
SECRET_KEY=یک-رشته-تصادفی-طولانی-برای-پروداکشن

ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

DB_NAME=amozeshgah_db
DB_USER=postgres
DB_PASSWORD=1
DB_HOST=localhost
DB_PORT=5432

TIME_ZONE=Asia/Tehran

# مسیر media روی سرور (اختیاری؛ پیش‌فرض: پوشه media پروژه)
# MEDIA_ROOT=/var/www/amozeshgah/media

# فقط برای تست بدون nginx؛ روی سرور واقعی False بگذار
SERVE_MEDIA=True
